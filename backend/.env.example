# Own database
DATABASE_URL=postgresql+asyncpg://imgscraper:imgscraper@db:5432/imgscraper
DATABASE_URL_SYNC=postgresql+psycopg2://imgscraper:imgscraper@db:5432/imgscraper

# WSK Hub database (read-only)
WSKHUB_DATABASE_URL=postgresql+asyncpg://wskhub:wskhub@host.docker.internal:5436/wskhub

# API Keys
GOOGLE_API_KEY=
GOOGLE_CX=
BING_API_KEY=

# Limits
GOOGLE_DAILY_LIMIT=100
BING_MONTHLY_LIMIT=1000

# Storage
IMAGE_STORAGE_PATH=/data/images
